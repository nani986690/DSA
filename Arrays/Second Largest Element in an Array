import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	int [] arr={10,20,80,11,55};
	int first=arr[0];
	int second=arr[0];
	for(int i=1;i<arr.length;i++){
	    if(arr[i]>first){
	        second=first;
	        first=arr[i];
	    }
	    else if(arr[i]>second){
	        second=arr[i];
	    }
	}
	System.out.println(second);
	}
}
